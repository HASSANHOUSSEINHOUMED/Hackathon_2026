# ═══════════════════════════════════════
# DocuFlow — Configuration environnement
# ═══════════════════════════════════════

# MinIO (Data Lake S3-compatible)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=localhost:9000

# MongoDB
MONGO_USER=admin
MONGO_PASSWORD=admin
MONGO_URI=mongodb://admin:admin@mongodb:27017/docuflow?authSource=admin

# Backend
PORT=4000
ADMIN_UI_PASSWORD=Admin@2026
OCR_SERVICE_URL=http://ocr-service:5001
VALIDATION_SERVICE_URL=http://validation-service:5002
STORAGE_API_KEY=docuflow-storage-key

# OpenAI (optionnel - pour le raffinement LLM)
OPENAI_API_KEY=

# Airflow
AIRFLOW_UID=50000
FERNET_KEY=
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres:5432/airflow
